DATABASE_PATH=./data/data.db
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
# The addresses the app is SERVED from (what users type in their browser), not the
# IP of each user's device. This is a security check, not a network setting: it does
# NOT control who on your network can open the app, it stops other websites from
# secretly using a logged-in user's session (CSRF). List every address the app is
# reached by, comma-separated, e.g. http://localhost:3000,http://192.168.1.100:3000
# Tip: give the server a fixed LAN IP so this stays a short, stable list.
# Avoid "*": it turns the check off and lets any website talk to your auth API.
TRUSTED_ORIGINS=http://localhost:3000
